#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-commit checks..."

# Use project venv binaries directly
VENV_BIN="$(git rev-parse --show-toplevel)/.venv/bin"

if [ ! -d "$VENV_BIN" ]; then
    echo "Error: .venv not found. Run 'make setup' first." >&2
    exit 1
fi

echo "  yamllint..."
"$VENV_BIN/yamllint" .

echo "  ansible-lint..."
"$VENV_BIN/ansible-lint"

echo "All checks passed."
